@model ClothingShop.Models.Product
@{
    ViewData["Title"] = "Chỉnh sửa Tồn kho & Giá";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Chỉnh sửa Tồn kho & Giá bán</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/Admin/Inventory/UpdateProduct">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />
                    
                    <!-- Tên sản phẩm (chỉ xem) -->
                    <div class="mb-3">
                        <label class="form-label">Sản phẩm</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="fas fa-box"></i></span>
                            <input type="text" class="form-control" value="@Model.Name" readonly />
                        </div>
                        <small class="text-muted">Không thể thay đổi tên sản phẩm ở đây</small>
                    </div>
                    
                    <!-- Số lượng tồn kho theo từng biến thể -->
                    <div class="mb-4">
                        <label class="form-label fw-bold"><i class="fas fa-boxes me-1"></i>Số lượng tồn kho chi tiết theo biến thể</label>
                        <div class="table-responsive border rounded p-2 bg-light">
                            <table class="table table-bordered table-striped align-middle mb-0">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Size</th>
                                        <th>Màu sắc</th>
                                        <th style="width: 200px;">Số lượng tồn kho <span class="text-danger">*</span></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var activeVariants = Model.ProductVariants != null
                                            ? ClothingShop.Common.ProductVariantHelper.FilterActiveVariants(Model).ToList()
                                            : new List<ClothingShop.Models.ProductVariant>();
                                    }
                                    @if (activeVariants.Any())
                                    {
                                        @foreach (var variant in activeVariants)
                                        {
                                            <tr>
                                                <td class="fw-bold">@variant.Size</td>
                                                <td>
                                                    <span class="badge bg-secondary p-2">@variant.Color</span>
                                                </td>
                                                <td>
                                                    <input type="number" 
                                                           name="variantQuantities[@variant.Id]" 
                                                           class="form-control text-center variant-qty-input" 
                                                           value="@variant.Quantity" 
                                                           min="0" 
                                                           required 
                                                           onchange="calculateTotalQty()" />
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center text-muted">
                                                Không tìm thấy biến thể nào. Hệ thống sẽ tự động đồng bộ khi bạn lưu.
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light">
                                    <tr class="fw-bold">
                                        <td colspan="2" class="text-end">Tổng tồn kho toàn bộ sản phẩm:</td>
                                        <td class="text-center text-primary fs-5" id="totalQtyIndicator">@Model.Quantity</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                        <small class="text-muted">Tổng số lượng của sản phẩm sẽ tự động tính bằng tổng tồn kho các biến thể.</small>
                    </div>
                    
                    <!-- Giá nhập và Giá bán -->
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Giá nhập (₫)</label>
                            <input type="number" name="cost" class="form-control" value="@(Model.Cost ?? 0)" min="0" step="1000" placeholder="Giá mua vào (tùy chọn)" />
                            <small class="text-muted">Giá mua từ nhà cung cấp</small>
                        </div>
                        
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Giá bán (₫) <span class="text-danger">*</span></label>
                            <input type="number" name="price" class="form-control" value="@Model.Price" min="0" step="1000" required />
                            <small class="text-muted">Giá hiển thị trên website</small>
                        </div>
                    </div>
                    
                    <!-- Thông báo -->
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Lưu ý:</strong> Thay đổi số lượng của từng biến thể sẽ được ghi lại trong lịch sử giao dịch kho tương ứng.
                    </div>
                    
                    <!-- Nút hành động -->
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Lưu thay đổi
                        </button>
                        <a href="/Admin/Inventory/LowStockAlert" class="btn btn-secondary">
                            <i class="fas fa-times me-1"></i>Hủy
                        </a>
                    </div>

@section Scripts {
    <script>
        function calculateTotalQty() {
            let total = 0;
            const inputs = document.querySelectorAll('.variant-qty-input');
            inputs.forEach(input => {
                const val = parseInt(input.value) || 0;
                total += val;
            });
            document.getElementById('totalQtyIndicator').textContent = total;
        }
    </script>
}
                </form>
            </div>
        </div>
    </div>
</div>
