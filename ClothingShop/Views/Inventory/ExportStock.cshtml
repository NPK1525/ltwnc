@{
    ViewData["Title"] = "Xuất kho";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="fas fa-arrow-up me-2"></i>Xuất hàng khỏi kho</h5>
            </div>
            <div class="card-body">
                <form method="post" action="/Admin/Inventory/ExportStock">
                    @Html.AntiForgeryToken()
                    
                    <div class="mb-3">
                        <label class="form-label">Sản phẩm <span class="text-danger">*</span></label>
                        
                        <!-- Widget Tìm Kiếm Sản Phẩm (Searchable Dropdown) -->
                        <div class="position-relative search-select-container">
                            <input type="text" id="productSearchInput" class="form-control" placeholder="🔍 Nhập tên sản phẩm để tìm kiếm..." autocomplete="off" />
                            <div id="productDropdownList" class="dropdown-menu w-100 shadow-lg overflow-auto" style="max-height: 280px; display: none; margin-top: 2px; z-index: 1050; border-radius: 8px;">
                                <div class="dropdown-header text-muted border-bottom pb-2 mb-1">-- Chọn sản phẩm dưới đây hoặc gõ tìm kiếm --</div>
                                @foreach (var product in ViewBag.Products)
                                {
                                    <button type="button" class="dropdown-item product-item d-flex justify-content-between align-items-center py-2 border-bottom" 
                                            data-id="@product.Id" 
                                            data-name="@product.Name"
                                            data-quantity="@product.Quantity">
                                        <div class="fw-bold text-wrap text-start me-3 text-secondary" style="max-width: 75%; font-size: 0.95rem;">@product.Name</div>
                                        <div class="text-nowrap text-end small">
                                            <span class="badge bg-secondary">Tồn: @product.Quantity</span>
                                        </div>
                                    </button>
                                }
                                <div id="noProductFound" class="p-3 text-center text-muted" style="display: none;">❌ Không tìm thấy sản phẩm nào</div>
                            </div>
                        </div>

                        <!-- Dropdown Select Ẩn để giữ nguyên logic MVC và validation -->
                        <select name="productId" id="productSelect" class="form-select" style="display: none;" required onchange="updateProductInfo()">
                            <option value="">-- Chọn sản phẩm --</option>
                            @foreach (var product in ViewBag.Products)
                            {
                                <option value="@product.Id" data-quantity="@product.Quantity">@product.Name (Tồn: @product.Quantity)</option>
                            }
                        </select>
                    </div>
                    
                    <!-- Lựa chọn biến thể Size & Màu sắc (Tách biệt để dễ quản lý) -->
                    <div class="row mb-3" id="variantWrapper" style="display: none;">
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Kích cỡ (Size) <span class="text-danger">*</span></label>
                            <select id="sizeSelect" class="form-select" required onchange="onSizeChange()">
                                <option value="">-- Chọn Size --</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label">Màu sắc <span class="text-danger">*</span></label>
                            <select id="colorSelect" class="form-select" required onchange="onColorChange()">
                                <option value="">-- Chọn Màu --</option>
                            </select>
                        </div>
                        <input type="hidden" name="variantId" id="variantIdHidden" required />
                    </div>

                    <!-- Thông tin tồn kho hiện tại của biến thể -->
                    <div id="currentInfo" class="alert alert-info" style="display: none;">
                        <strong>Tồn kho của biến thể hiện tại:</strong> <span id="currentQuantity" class="text-primary fw-bold">0</span>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Số lượng xuất <span class="text-danger">*</span></label>
                        <input type="number" name="quantity" class="form-control" min="1" required />
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label">Lý do xuất <span class="text-danger">*</span></label>
                        <select name="reason" class="form-select" required>
                            <option value="">-- Chọn lý do --</option>
                            <option value="Hàng hỏng">Hàng hỏng</option>
                            <option value="Hàng lỗi">Hàng lỗi</option>
                            <option value="Khuyến mãi">Khuyến mãi</option>
                            <option value="Hủy">Hủy</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>
                    
                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Lưu ý: Số lượng tồn kho của biến thể sẽ bị trừ đi sau khi xuất!
                    </div>
                    
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning">
                            <i class="fas fa-check me-1"></i>Xuất kho
                        </button>
                        <a href="/Admin/Inventory" class="btn btn-secondary">
                            <i class="fas fa-times me-1"></i>Hủy
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentVariants = [];

        async function updateProductInfo() {
            const select = document.getElementById('productSelect');
            const option = select.options[select.selectedIndex];
            
            const variantWrapper = document.getElementById('variantWrapper');
            const sizeSelect = document.getElementById('sizeSelect');
            const colorSelect = document.getElementById('colorSelect');
            const variantIdHidden = document.getElementById('variantIdHidden');
            
            // Xóa dữ liệu cũ
            sizeSelect.innerHTML = '<option value="">-- Chọn Size --</option>';
            colorSelect.innerHTML = '<option value="">-- Chọn Màu --</option>';
            variantIdHidden.value = '';
            document.getElementById('currentInfo').style.display = 'none';
            variantWrapper.style.display = 'none';

            if (option.value) {
                const productId = option.value;
                
                try {
                    const response = await fetch(`/Admin/Inventory/GetVariants?productId=${productId}`);
                    if (response.ok) {
                        currentVariants = await response.json();
                        
                        // Lấy danh sách size độc nhất
                        const uniqueSizes = [...new Set(currentVariants.map(v => v.size))];
                        
                        uniqueSizes.forEach(size => {
                            const opt = document.createElement('option');
                            opt.value = size;
                            opt.textContent = size;
                            sizeSelect.appendChild(opt);
                        });

                        variantWrapper.style.display = 'flex';
                    }
                } catch (e) {
                    console.error("Lỗi khi tải biến thể:", e);
                }
            }
        }

        function onSizeChange() {
            const sizeSelect = document.getElementById('sizeSelect');
            const colorSelect = document.getElementById('colorSelect');
            const variantIdHidden = document.getElementById('variantIdHidden');
            
            const selectedSize = sizeSelect.value;
            
            // Xóa màu cũ
            colorSelect.innerHTML = '<option value="">-- Chọn Màu --</option>';
            variantIdHidden.value = '';
            document.getElementById('currentInfo').style.display = 'none';
            
            if (selectedSize) {
                // Lọc các màu của size tương ứng
                const availableVariants = currentVariants.filter(v => v.size === selectedSize);
                
                availableVariants.forEach(variant => {
                    const opt = document.createElement('option');
                    opt.value = variant.color;
                    opt.textContent = `${variant.color} (Tồn: ${variant.quantity})`;
                    opt.dataset.variantId = variant.id;
                    opt.dataset.quantity = variant.quantity;
                    colorSelect.appendChild(opt);
                });
            }
        }

        function onColorChange() {
            const sizeSelect = document.getElementById('sizeSelect');
            const colorSelect = document.getElementById('colorSelect');
            const option = colorSelect.options[colorSelect.selectedIndex];
            const variantIdHidden = document.getElementById('variantIdHidden');

            if (option.value) {
                const variantId = option.dataset.variantId;
                const quantity = parseInt(option.dataset.quantity);

                variantIdHidden.value = variantId;
                document.getElementById('currentQuantity').textContent = quantity;
                document.getElementById('currentInfo').style.display = 'block';
                
                // Cấu hình giới hạn tối đa cho input số lượng xuất
                const qtyInput = document.querySelector('input[name="quantity"]');
                if (qtyInput) {
                    qtyInput.max = quantity;
                    qtyInput.value = Math.min(qtyInput.value || 1, quantity);
                }
            } else {
                variantIdHidden.value = '';
                document.getElementById('currentInfo').style.display = 'none';
            }
        }
        
        // Cấu hình Ô Tìm Kiếm Sản Phẩm (Searchable Dropdown)
        const searchInput = document.getElementById('productSearchInput');
        const hiddenSelect = document.getElementById('productSelect');
        const dropdownList = document.getElementById('productDropdownList');
        const productItems = document.querySelectorAll('.product-item');
        const noProductFound = document.getElementById('noProductFound');

        // Hiển thị danh sách khi focus vào ô tìm kiếm
        searchInput.addEventListener('focus', () => {
            dropdownList.style.display = 'block';
        });

        // Ẩn danh sách khi click ra ngoài vùng container
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.search-select-container')) {
                dropdownList.style.display = 'none';
            }
        });

        // Tìm kiếm sản phẩm khi gõ phím
        searchInput.addEventListener('input', () => {
            const query = searchInput.value.toLowerCase().trim();
            let matches = 0;
            
            productItems.forEach(item => {
                const name = item.dataset.name.toLowerCase();
                if (name.includes(query)) {
                    item.style.setProperty('display', 'flex', 'important');
                    matches++;
                } else {
                    item.style.setProperty('display', 'none', 'important');
                }
            });
            
            if (matches === 0) {
                noProductFound.style.display = 'block';
            } else {
                noProductFound.style.display = 'none';
            }
            dropdownList.style.display = 'block';
        });

        // Xử lý khi click chọn một sản phẩm
        productItems.forEach(item => {
            item.addEventListener('click', () => {
                const id = item.dataset.id;
                const name = item.dataset.name;
                const quantity = item.dataset.quantity;
                
                searchInput.value = `${name} (Tồn: ${quantity})`;
                hiddenSelect.value = id;
                
                dropdownList.style.display = 'none';
                
                // Gọi hàm updateProductInfo của hệ thống để tải biến thể
                updateProductInfo();
            });
        });
        
        // Khởi tạo hiển thị nếu có sản phẩm chọn sẵn
        function initSearchSelect() {
            if (hiddenSelect.value) {
                const selectedOption = hiddenSelect.options[hiddenSelect.selectedIndex];
                if (selectedOption && selectedOption.value) {
                    searchInput.value = selectedOption.text.trim();
                }
            }
        }

        document.addEventListener('DOMContentLoaded', function() {
            // Khởi tạo giá trị cho ô input tìm kiếm dựa trên select ẩn
            initSearchSelect();

            if (document.getElementById('productSelect').value) {
                updateProductInfo();
            }
        });
    </script>
}
