@model ClothingShop.Models.Voucher
@using ClothingShop.Models.Enums
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chỉnh sửa Voucher";
    bool hasBeenUsed = Model.UsedCount > 0;
}

<div class="row mb-3">
    <div class="col">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/Admin">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/Admin/Vouchers">Quản lý Voucher</a></li>
                <li class="breadcrumb-item active" aria-current="page">Chỉnh sửa</li>
            </ol>
        </nav>
        <h4 class="fw-bold"><i class="fas fa-edit text-warning me-2"></i>Chỉnh sửa Mã giảm giá: @Model.Code</h4>
    </div>
</div>

@if (hasBeenUsed)
{
    <div class="alert alert-warning border-0 shadow-sm mb-4">
        <div class="d-flex">
            <div class="me-3">
                <i class="fas fa-exclamation-triangle fa-2x text-warning"></i>
            </div>
            <div>
                <h6 class="fw-bold mb-1">Mã giảm giá này đã được sử dụng!</h6>
                <p class="mb-0 small text-muted">Voucher này đã được áp dụng trong <strong>@Model.UsedCount đơn hàng</strong> thực tế. Để bảo toàn tính nhất quán lịch sử đơn hàng, các trường cấu hình cốt lõi (Mã, Loại giảm, Mức giảm, Hạn mức tối thiểu) đã bị **khóa không cho chỉnh sửa**. Bạn vẫn có thể gia hạn ngày kết thúc, tăng tổng lượt sử dụng hoặc bật/tắt kích hoạt mã.</p>
            </div>
        </div>
    </div>
}

<div class="row">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <form action="/Admin/Vouchers/Edit/@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="UsedCount" />
                    
                    @if (hasBeenUsed)
                    {
                        <!-- Lưu các trường bị disabled vào hidden input để gửi lên server không bị mất dữ liệu -->
                        <input type="hidden" asp-for="Code" />
                        <input type="hidden" asp-for="DiscountType" />
                        <input type="hidden" asp-for="DiscountValue" />
                        <input type="hidden" asp-for="MaxDiscountAmount" />
                        <input type="hidden" asp-for="MinOrderAmount" />
                        <input type="hidden" asp-for="StartDate" />
                        <input type="hidden" asp-for="LimitPerUser" />
                    }

                    <div class="row g-3">
                        <!-- Code -->
                        <div class="col-md-6">
                            <label asp-for="Code" class="form-label fw-bold small">Mã giảm giá</label>
                            <input asp-for="Code" class="form-control text-uppercase font-monospace border-2 @(hasBeenUsed ? "bg-light text-muted" : "")" placeholder="Ví dụ: SUMMER50K" required disabled="@hasBeenUsed" />
                            <span asp-validation-for="Code" class="text-danger small"></span>
                        </div>

                        <!-- Trạng thái hoạt động ban đầu -->
                        <div class="col-md-6 d-flex align-items-center mt-md-4">
                            <div class="form-check form-switch p-3 border rounded bg-light w-100 ps-5 ms-0 mt-2">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label fw-bold small">Kích hoạt hoạt động</label>
                            </div>
                        </div>

                        <!-- Mô tả -->
                        <div class="col-12">
                            <label asp-for="Description" class="form-label fw-bold small">Mô tả chương trình khuyến mãi</label>
                            <textarea asp-for="Description" class="form-control border-2" rows="2" placeholder="Nhập mô tả hiển thị cho khách hàng biết (Ví dụ: Giảm 20% đơn từ 200k)"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <hr class="my-4 text-muted">

                        <!-- Loại và giá trị giảm -->
                        <div class="col-md-6">
                            <label asp-for="DiscountType" class="form-label fw-bold small">Loại giảm giá</label>
                            <select asp-for="DiscountType" id="discountTypeSelect" class="form-select border-2 @(hasBeenUsed ? "bg-light text-muted" : "")" disabled="@hasBeenUsed">
                                <option value="Percentage">Giảm theo phần trăm (%)</option>
                                <option value="FixedAmount">Giảm theo số tiền (đ)</option>
                            </select>
                            <span asp-validation-for="DiscountType" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="DiscountValue" class="form-label fw-bold small">Giá trị giảm giá</label>
                            <div class="input-group">
                                <input asp-for="DiscountValue" type="number" step="any" class="form-control border-2 @(hasBeenUsed ? "bg-light text-muted" : "")" placeholder="Nhập số tiền hoặc số %" required disabled="@hasBeenUsed" />
                                <span class="input-group-text bg-light border-2 border-start-0" id="discountValueAddon">%</span>
                            </div>
                            <span asp-validation-for="DiscountValue" class="text-danger small"></span>
                        </div>

                        <!-- Capped max amount for percentage type -->
                        <div class="col-md-6" id="maxDiscountRow">
                            <label asp-for="MaxDiscountAmount" class="form-label fw-bold small">Số tiền giảm tối đa (Tùy chọn)</label>
                            <div class="input-group">
                                <input asp-for="MaxDiscountAmount" type="number" step="0.01" class="form-control border-2 @(hasBeenUsed ? "bg-light text-muted" : "")" placeholder="Nhập số tiền giảm tối đa" disabled="@hasBeenUsed" />
                                <span class="input-group-text bg-light border-2 border-start-0">₫</span>
                            </div>
                            <span asp-validation-for="MaxDiscountAmount" class="text-danger small"></span>
                        </div>

                        <!-- Min Order Amount -->
                        <div class="col-md-6">
                            <label asp-for="MinOrderAmount" class="form-label fw-bold small">Giá trị đơn hàng tối thiểu</label>
                            <div class="input-group">
                                <input asp-for="MinOrderAmount" type="number" step="0.01" class="form-control border-2 @(hasBeenUsed ? "bg-light text-muted" : "")" placeholder="Ví dụ: 150000" required disabled="@hasBeenUsed" />
                                <span class="input-group-text bg-light border-2 border-start-0">₫</span>
                            </div>
                            <span asp-validation-for="MinOrderAmount" class="text-danger small"></span>
                        </div>

                        <hr class="my-4 text-muted">

                        <!-- Start and End dates -->
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-bold small">Ngày bắt đầu hiệu lực</label>
                            <input asp-for="StartDate" type="datetime-local" class="form-control border-2 @(hasBeenUsed ? "bg-light text-muted" : "")" required disabled="@hasBeenUsed" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-bold small">Ngày hết hạn hiệu lực <span class="text-danger">*</span></label>
                            <input asp-for="EndDate" type="datetime-local" class="form-control border-2" required />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>

                        <!-- UsageLimit and LimitPerUser -->
                        <div class="col-md-6">
                            <label asp-for="UsageLimit" class="form-label fw-bold small">Tổng số lượt sử dụng tối đa</label>
                            <input asp-for="UsageLimit" type="number" class="form-control border-2" placeholder="Bỏ trống nếu không giới hạn số lần dùng" />
                            <span asp-validation-for="UsageLimit" class="text-danger small"></span>
                            <div class="form-text text-muted small">Đã sử dụng thực tế: <strong>@Model.UsedCount</strong> lượt</div>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="LimitPerUser" class="form-label fw-bold small">Số lượt dùng tối đa trên mỗi khách hàng</label>
                            <input asp-for="LimitPerUser" type="number" class="form-control border-2 @(hasBeenUsed ? "bg-light text-muted" : "")" required disabled="@hasBeenUsed" />
                            <span asp-validation-for="LimitPerUser" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mt-4 pt-3 border-top d-flex gap-2">
                        <button type="submit" class="btn btn-warning text-dark px-4 py-2"><i class="fas fa-save me-2"></i>Lưu thay đổi</button>
                        <a href="/Admin/Vouchers" class="btn btn-outline-secondary px-4 py-2"><i class="fas fa-arrow-left me-2"></i>Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
    
    <div class="col-lg-4 mt-4 mt-lg-0">
        <div class="card bg-light border-0 shadow-sm mb-3">
            <div class="card-body p-4">
                <h6 class="fw-bold mb-3"><i class="fas fa-info-circle text-primary me-2"></i>Chỉnh sửa thông số:</h6>
                <p class="small text-muted">Nếu mã chưa có đơn hàng nào áp dụng, bạn hoàn toàn có thể thay đổi toàn bộ thuộc tính.</p>
                <p class="small text-muted">Nếu mã đã hoạt động và được dùng, bạn vẫn có thể chỉnh sửa mô tả, bật/tắt để dừng phát hành mã, tăng tổng lượt sử dụng tối đa hoặc kéo dài thời gian hết hạn.</p>
            </div>
        </div>
        
        <div class="card border-0 shadow-sm text-center py-4 bg-white">
            <div class="card-body">
                <h3 class="fw-bold text-success m-0">@Model.UsedCount</h3>
                <p class="text-muted small m-0 mb-3">Lượt sử dụng thực tế</p>
                <div class="d-grid px-3">
                    <a href="/Admin/Vouchers/Details/@Model.Id" class="btn btn-sm btn-outline-primary"><i class="fas fa-history me-1"></i>Xem lịch sử dùng</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const select = document.getElementById('discountTypeSelect');
            const addon = document.getElementById('discountValueAddon');
            const maxRow = document.getElementById('maxDiscountRow');

            function toggleType() {
                if (select.value === 'Percentage') {
                    addon.textContent = '%';
                    maxRow.style.display = 'block';
                } else {
                    addon.textContent = '₫';
                    maxRow.style.display = 'none';
                }
            }

            // Chỉ cần chạy trên client nếu không bị disabled
            if (!@hasBeenUsed.ToString().ToLower()) {
                select.addEventListener('change', toggleType);
            }
            toggleType();
        });
    </script>
}
