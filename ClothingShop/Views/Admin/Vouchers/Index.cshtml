@model IEnumerable<ClothingShop.Models.Voucher>
@using ClothingShop.Models.Enums
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý mã Voucher";
    
    var currentStatus = ViewBag.CurrentStatus as string;
    var currentType = ViewBag.CurrentType as string;
    var now = DateTime.Now;
}

<div class="row mb-4 align-items-center">
    <div class="col-md-6">
        <h4 class="fw-bold text-dark m-0"><i class="fas fa-ticket-alt text-primary me-2"></i>Danh sách Mã giảm giá</h4>
        <p class="text-muted small m-0">Tạo, cập nhật cấu hình và theo dõi tình trạng sử dụng các mã khuyến mãi</p>
    </div>
    <div class="col-md-6 text-md-end mt-3 mt-md-0">
        <a href="/Admin/Vouchers/Create" class="btn btn-primary px-4 py-2 shadow-sm rounded-pill">
            <i class="fas fa-plus me-2"></i>Thêm mới Voucher
        </a>
    </div>
</div>

<!-- Bộ lọc -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-3">
        <form method="get" action="/Admin/Vouchers" class="row g-3 align-items-end">
            <div class="col-md-4 col-sm-6">
                <label class="form-label text-muted small fw-bold">Trạng thái mã</label>
                <select name="status" class="form-select border-2 shadow-none" onchange="this.form.submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(currentStatus))">Tất cả trạng thái</option>
                    <option value="active" selected="@(currentStatus == "active")">Đang hoạt động tốt</option>
                    <option value="inactive" selected="@(currentStatus == "inactive")">Bị tắt kích hoạt</option>
                    <option value="expired" selected="@(currentStatus == "expired")">Đã hết hạn dùng</option>
                    <option value="exhausted" selected="@(currentStatus == "exhausted")">Đã hết lượt dùng</option>
                </select>
            </div>
            <div class="col-md-4 col-sm-6">
                <label class="form-label text-muted small fw-bold">Loại giảm giá</label>
                <select name="type" class="form-select border-2 shadow-none" onchange="this.form.submit()">
                    <option value="" selected="@(string.IsNullOrEmpty(currentType))">Tất cả loại</option>
                    <option value="Percentage" selected="@(currentType == "Percentage")">Giảm theo %</option>
                    <option value="FixedAmount" selected="@(currentType == "FixedAmount")">Giảm số tiền cố định</option>
                </select>
            </div>
            <div class="col-md-4 text-md-end text-center d-flex gap-2">
                <button type="submit" class="btn btn-dark w-100 py-2"><i class="fas fa-filter me-2"></i>Lọc dữ liệu</button>
                <a href="/Admin/Vouchers" class="btn btn-outline-secondary w-100 py-2"><i class="fas fa-undo me-2"></i>Đặt lại</a>
            </div>
        </form>
    </div>
</div>

<!-- Danh sách -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted uppercase small">
                    <tr>
                        <th class="ps-4">Mã Voucher</th>
                        <th>Thông tin giảm giá</th>
                        <th>Đơn tối thiểu</th>
                        <th>Giới hạn dùng</th>
                        <th>Thời hạn</th>
                        <th>Trạng thái</th>
                        <th class="text-end pe-4">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5 text-muted">
                                <i class="fas fa-folder-open fa-3x mb-3 text-secondary"></i>
                                <p class="m-0 fw-bold">Không tìm thấy mã giảm giá nào phù hợp!</p>
                                <p class="text-muted small">Hãy nhấn nút "Thêm mới Voucher" để tạo mã đầu tiên.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var voucher in Model)
                        {
                            bool isExpired = voucher.EndDate < now;
                            bool isExhausted = voucher.UsageLimit.HasValue && voucher.UsedCount >= voucher.UsageLimit.Value;
                            bool isActiveNow = voucher.IsActive && voucher.StartDate <= now && !isExpired && !isExhausted;

                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-sm bg-primary bg-opacity-10 text-primary rounded p-2 me-3 text-center" style="width: 42px; height: 42px; line-height: 26px;">
                                            <i class="fas fa-ticket-alt"></i>
                                        </div>
                                        <div>
                                            <span class="badge bg-secondary font-monospace fs-6 text-dark border border-secondary border-opacity-50 px-2 py-1">@voucher.Code</span>
                                            @if (!string.IsNullOrEmpty(voucher.Description))
                                            {
                                                <div class="text-muted small mt-1 text-truncate" style="max-width: 200px;">@voucher.Description</div>
                                            }
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    @if (voucher.DiscountType == VoucherDiscountType.Percentage)
                                    {
                                        <span class="fw-bold text-success"><i class="fas fa-percentage me-1"></i>Giảm @voucher.DiscountValue.ToString("G29")%</span>
                                        if (voucher.MaxDiscountAmount.HasValue)
                                        {
                                            <div class="text-muted small">Tối đa: @voucher.MaxDiscountAmount.Value.ToString("N0")₫</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="fw-bold text-success"><i class="fas fa-wallet me-1"></i>Giảm -@voucher.DiscountValue.ToString("N0")₫</span>
                                    }
                                </td>
                                <td class="fw-bold text-dark">
                                    @(voucher.MinOrderAmount > 0 ? voucher.MinOrderAmount.ToString("N0") + "₫" : "0₫")
                                </td>
                                <td>
                                    <div class="d-flex align-items-center justify-content-between mb-1 small text-muted">
                                        <span>Đã dùng: @voucher.UsedCount</span>
                                        <span>Tổng: @(voucher.UsageLimit.HasValue ? voucher.UsageLimit.Value.ToString() : "∞")</span>
                                    </div>
                                    @if (voucher.UsageLimit.HasValue && voucher.UsageLimit.Value > 0)
                                    {
                                        var percent = (int)Math.Min(100, (double)voucher.UsedCount / voucher.UsageLimit.Value * 100);
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar @(percent >= 90 ? "bg-danger" : percent >= 60 ? "bg-warning" : "bg-primary")" role="progressbar" style="width: @percent%"></div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-info" role="progressbar" style="width: 0%"></div>
                                        </div>
                                    }
                                </td>
                                <td class="small">
                                    <div class="text-muted">Bắt đầu: @voucher.StartDate.ToString("dd/MM/yyyy")</div>
                                    <div class="@(isExpired ? "text-danger fw-bold" : "text-muted")">
                                        Kết thúc: @voucher.EndDate.ToString("dd/MM/yyyy")
                                        @if (isExpired)
                                        {
                                            <span class="badge bg-danger bg-opacity-10 text-danger ms-1 py-0 px-1" style="font-size: 0.7rem;">Hết hạn</span>
                                        }
                                    </div>
                                </td>
                                <td>
                                    @if (isActiveNow)
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success px-2 py-1"><i class="fas fa-check-circle me-1"></i>Hoạt động</span>
                                    }
                                    else if (!voucher.IsActive)
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary px-2 py-1"><i class="fas fa-pause-circle me-1"></i>Tắt kích hoạt</span>
                                    }
                                    else if (isExhausted)
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger px-2 py-1"><i class="fas fa-times-circle me-1"></i>Hết lượt</span>
                                    }
                                    else if (voucher.StartDate > now)
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning px-2 py-1"><i class="fas fa-clock me-1"></i>Chờ hiệu lực</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        <a href="/Admin/Vouchers/Details/@voucher.Id" class="btn btn-outline-primary btn-sm rounded-circle p-1" title="Chi tiết & Lịch sử dùng" style="width: 30px; height: 30px; line-height: 20px; text-align: center;">
                                            <i class="fas fa-eye text-primary"></i>
                                        </a>
                                        <a href="/Admin/Vouchers/Edit/@voucher.Id" class="btn btn-outline-warning btn-sm rounded-circle p-1" title="Chỉnh sửa" style="width: 30px; height: 30px; line-height: 20px; text-align: center;">
                                            <i class="fas fa-edit text-warning"></i>
                                        </a>
                                        
                                        <form action="/Admin/Vouchers/ToggleActive/@voucher.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn @(voucher.IsActive ? "btn-outline-secondary" : "btn-outline-success") btn-sm rounded-circle p-1" style="width: 30px; height: 30px; line-height: 20px; text-align: center;" title="@(voucher.IsActive ? "Tạm ngưng hoạt động" : "Kích hoạt trở lại")">
                                                <i class="fas @(voucher.IsActive ? "fa-ban" : "fa-play")"></i>
                                            </button>
                                        </form>

                                        <form action="/Admin/Vouchers/Delete/@voucher.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có thực sự muốn xóa voucher @voucher.Code? Nếu mã đã được sử dụng, hệ thống sẽ ngưng kích hoạt thay vì xóa vĩnh viễn.')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-circle p-1" style="width: 30px; height: 30px; line-height: 20px; text-align: center;" title="Xóa">
                                                <i class="fas fa-trash-alt text-danger"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
